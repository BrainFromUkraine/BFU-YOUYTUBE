# BFU YouTube Subscriber Counter — Backend ENV variables
# Copy this file to .env for local development.
# Set these as Railway Variables in your Railway project dashboard.

# ─── REQUIRED ────────────────────────────────────────────────────────────────
# Your YouTube Data API v3 key from Google Cloud Console
# https://console.cloud.google.com/ → APIs & Services → Credentials
YOUTUBE_API_KEY=PASTE_YOUR_API_KEY_HERE

# Your YouTube channel ID (starts with UC...)
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── OPTIONAL ────────────────────────────────────────────────────────────────
# How many seconds to cache the YouTube API response (default: 30)
CACHE_TTL_SECONDS=30

# Optional device token for ESP32 authentication.
# If set, ESP32 must send header: X-Device-Token: <this value>
# Leave empty to disable auth.
DEVICE_API_TOKEN=
